# ============================================================
# .creds 凭据文件模板
# ============================================================
# 用法：复制本文件为 .creds，把每个 REPLACE_ME_xxx 整行替换为真实值
#   cp .creds.example .creds
#   chmod 600 .creds
#   nano .creds   ← 编辑替换
#
# 格式规则：
#   - 每个字段独占一行
#   - 以 # 开头的行 + 空行 全部被忽略（你可以保留这些注释帮助记忆）
#   - 不要加引号、空格、尾随空白
#   - 顺序必须是：HOST → PORT → USER → PASSWORD
# ============================================================

# ─────────────────────────────────────────────
# 字段 1: 服务器 IP 或域名
#   例如：129.226.211.33
# ─────────────────────────────────────────────
REPLACE_ME_HOST

# ─────────────────────────────────────────────
# 字段 2: SSH 端口
#   例如：22
# ─────────────────────────────────────────────
REPLACE_ME_PORT

# ─────────────────────────────────────────────
# 字段 3: SSH 用户名
#   例如：ubuntu
# ─────────────────────────────────────────────
REPLACE_ME_USER

# ─────────────────────────────────────────────
# 字段 4: SSH 密码  *或*  私钥路径
#   - 密码：直接填密码字符串，不要加引号
#   - 私钥：填路径（含 / 或以 ~ 开头即被识别为私钥）
#       例 ~/.ssh/seat_test_ed25519
#       例 scripts/test.key       （相对路径以项目根为基准）
#       例 /abs/path/to/key
# ─────────────────────────────────────────────
REPLACE_ME_PASSWORD
